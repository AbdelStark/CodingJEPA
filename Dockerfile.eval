# syntax=docker/dockerfile:1.7
#
# Dockerfile.eval — reproducible image for `make eval`.
#
# Pinned base: nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04 (RFC-0013 §D2 pins CUDA 12.4).
# For release builds, pin by digest — see docs/spec/09-release-and-versioning.md §Eval image
# digest pin procedure.
#
# Intended use:
#   docker build -f Dockerfile.eval -t codingjepa-eval:test .
#   docker run --rm --gpus all codingjepa-eval:test
#
# CI builds this image (without a GPU) to validate the Dockerfile compiles; the published
# release image is built and pushed to GHCR by the release runbook (RFC-0011 §D7).

FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

# Avoid interactive tzdata/etc. prompts during apt-get.
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# System dependencies. Python 3.12 is the only supported interpreter (RFC-0013 §D3).
# python3.12 is not in the default ubuntu:22.04 apt repos — pull it from deadsnakes.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        software-properties-common \
 && add-apt-repository -y ppa:deadsnakes/ppa \
 && apt-get update \
 && apt-get install -y --no-install-recommends \
        python3.12 \
        python3.12-venv \
        python3.12-dev \
 && rm -rf /var/lib/apt/lists/*

# Install uv (matches astral-sh/setup-uv version pinned in .github/workflows/*.yml).
RUN curl -LsSf https://astral.sh/uv/0.8.17/install.sh | sh
ENV PATH="/root/.local/bin:/root/.cargo/bin:${PATH}"

WORKDIR /workspace

# Copy dependency manifests first so the dependency-resolution layer is cached and only
# invalidated when pyproject.toml or uv.lock changes.
COPY pyproject.toml uv.lock ./

# Install runtime dependencies only (no dev extras) into the project venv. --frozen
# ensures the resolved versions match uv.lock exactly.
RUN uv sync --frozen --no-dev

# Copy the package, configs, and Makefile required for `make eval`.
COPY codingjepa/ ./codingjepa/
COPY config/ ./config/
COPY Makefile ./

ENTRYPOINT ["uv", "run", "make", "eval"]
